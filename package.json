{
  "name": "ricki-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "biome check . && eslint --config eslint.astro.config.js 'src/**/*.astro'",
    "lint:fix": "biome check --write . && eslint --fix --config eslint.astro.config.js 'src/**/*.astro'",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint-staged": "lint-staged",
    "test": "vitest",
    "test:ui": "vitest --ui --coverage",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@mediapipe/tasks-vision": "^0.10.33",
    "@nanostores/react": "^1.1.0",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.2",
    "astro-robots-txt": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "nanostores": "^1.3.0",
    "opentype.js": "^1.3.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/node20": "^20.1.6",
    "@types/node": "^24.10.4",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.0.7",
    "@vitest/ui": "^4.0.7",
    "autoprefixer": "^10.4.22",
    "danger": "^13.0.7",
    "eslint": "^9.28.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.1",
    "vitest": "^4.0.7"
  },
  "packageManager": "bun@1.3.11"
}
